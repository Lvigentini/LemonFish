# ============================================================
# MiroFish [LemonFish] — Environment Configuration Reference
# ============================================================
# This file documents every environment variable the app reads.
# Copy to .env and fill in only what you need — unset vars fall
# back to sensible defaults.
#
# Run ./setup.sh for an interactive wizard that generates a
# minimal .env, or fill it in manually below.
#
# See docs/llm_providers.md for the verified provider catalogue
# (updated weekly via the GitHub Actions drift check).
# ============================================================


# ============================================================
# SECTION 1 — Primary LLM (REQUIRED)
# ============================================================
# Every pipeline step that doesn't have a per-step override uses
# these three variables. Pick ONE provider from the examples at
# the bottom of this file and paste the three values here.

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free


# ============================================================
# SECTION 2 — Fallback models (Phase 0 resilience)
# ============================================================
# Comma-separated list of models to try when the primary
# returns 429 / 5xx / timeout. Only relevant when LLM_BASE_URL
# points at a provider that can serve multiple models under
# one API key (OpenRouter is the main use case).
LLM_FALLBACK_MODELS=nousresearch/hermes-3-llama-3.1-405b:free,qwen/qwen3-235b-a22b:free,deepseek/deepseek-chat:free,openrouter/free

# Retry behaviour — applied to every LLM call in every step.
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=2.0


# ============================================================
# SECTION 3 — Per-step model overrides (Phase 2)
# ============================================================
# Each pipeline step can use a different provider/model. When
# a step's block is unset, it falls back to the primary LLM_*
# config above. Recommended routing:
#
#   Step 1 Ontology    → large-context (Gemini 3 Flash, 1M ctx)
#   Step 2 Profiles    → cheap JSON-capable (Groq, gpt-5-nano)
#   Step 3 Config      → cheap JSON-capable
#   Step 4 Simulation  → free/cheap (~90% of total tokens)
#   Step 5 Report      → reasoning-capable (Claude, Gemini Pro)

# --- Step 1: Ontology ---
# LLM_ONTOLOGY_API_KEY=your_google_ai_studio_key
# LLM_ONTOLOGY_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_ONTOLOGY_MODEL=gemini-3-flash-preview
# LLM_ONTOLOGY_MAX_TEXT_LENGTH=2000000

# --- Step 2: Profiles ---
# LLM_PROFILES_API_KEY=gsk_your_groq_key
# LLM_PROFILES_BASE_URL=https://api.groq.com/openai/v1
# LLM_PROFILES_MODEL=llama-3.1-8b-instant

# --- Step 3: Config generation ---
# LLM_CONFIG_API_KEY=
# LLM_CONFIG_BASE_URL=
# LLM_CONFIG_MODEL=

# --- Step 4: Simulation (dominates token cost) ---
# LLM_SIMULATION_API_KEY=gsk_your_groq_key
# LLM_SIMULATION_BASE_URL=https://api.groq.com/openai/v1
# LLM_SIMULATION_MODEL=llama-3.1-8b-instant

# --- Step 5: Report generation ---
# LLM_REPORT_API_KEY=
# LLM_REPORT_BASE_URL=
# LLM_REPORT_MODEL=


# ============================================================
# SECTION 4 — Multi-provider pool (Phase 4 + Phase 6)
# ============================================================
# Spreads agent LLM calls across multiple providers to stretch
# free-tier budgets. Agents are randomly allocated to a provider
# at simulation start and locked for the run. See Phase 6 /
# docs/new_features_planning.md for rationale.
#
# Set LLM_PROVIDERS to a comma-separated list of provider names,
# then add a block per provider with LLM_<NAME>_* variables.
# Names are lowercased in LLM_PROVIDERS and uppercased in each
# block's variable names.
#
# If LLM_PROVIDERS is unset, multi-provider mode is disabled
# and all calls use the primary LLM_* config.

# LLM_PROVIDERS=groq,google,openrouter,ollama

# --- Groq ---
# LLM_GROQ_API_KEY=gsk_...
# LLM_GROQ_BASE_URL=https://api.groq.com/openai/v1
# LLM_GROQ_MODEL=llama-3.1-8b-instant
# LLM_GROQ_DAILY_TOKEN_BUDGET=500000

# --- Google Gemini ---
# LLM_GOOGLE_API_KEY=AIza...
# LLM_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_GOOGLE_MODEL=gemini-3-flash-preview
# LLM_GOOGLE_DAILY_TOKEN_BUDGET=1000000

# --- OpenRouter ---
# LLM_OPENROUTER_API_KEY=sk-or-v1-...
# LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# LLM_OPENROUTER_DAILY_TOKEN_BUDGET=200000

# --- Ollama (local, no API key needed) ---
# LLM_OLLAMA_API_KEY=ollama
# LLM_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# LLM_OLLAMA_MODEL=llama3.2
# LLM_OLLAMA_DAILY_TOKEN_BUDGET=999999999

# Reproducibility seed for agent-to-provider allocation. If unset,
# a random seed is chosen per simulation. Set to any integer to
# make the allocation deterministic across runs.
# LLM_MULTI_PROVIDER_SEED=42


# ============================================================
# SECTION 5 — Legacy dual-LLM boost (parallel simulation)
# ============================================================
# Predates the multi-provider pool. If set, the parallel
# simulation runner uses these credentials for one of its two
# platform subprocesses to cut wall-clock time. Superseded by
# Section 4 for most users — leave unset unless you specifically
# want the dual-provider split by platform.

# LLM_BOOST_API_KEY=
# LLM_BOOST_BASE_URL=
# LLM_BOOST_MODEL_NAME=


# ============================================================
# SECTION 6 — Zep Cloud (REQUIRED)
# ============================================================
# Knowledge graph storage. Free tier is sufficient for basic
# usage. Sign up at: https://app.getzep.com/

ZEP_API_KEY=your_zep_api_key_here


# ============================================================
# SECTION 7 — OASIS simulation settings
# ============================================================
# Default maximum number of rounds if the user doesn't override
# in the UI. Each round is one "tick" of simulated time.
OASIS_DEFAULT_MAX_ROUNDS=10


# ============================================================
# SECTION 8 — Report Agent tuning (Phase 0 defaults usually fine)
# ============================================================
# Controls the ReACT loop that generates the final prediction
# report. Only touch if you're seeing truncated reports or
# excessive tool-call usage.

# REPORT_AGENT_MAX_TOOL_CALLS=5
# REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
# REPORT_AGENT_TEMPERATURE=0.5


# ============================================================
# SECTION 9 — Research-from-prompt module (Phase 8, opt-in)
# ============================================================
# When RESEARCH_ENABLED=true, the backend mounts /api/research/*
# and the frontend exposes a "Start with research" Step 0 entry
# point. The user describes what they want to predict instead of
# uploading documents; research agents gather material via web
# search and compile it into the existing pipeline.
#
# Available runners (RESEARCH_RUNNERS = comma-separated subset):
#   - api     Always available in the slim Docker image (ddgs
#             + primary LLM). No external CLI dependencies.
#   - claude  Shells out to Claude Code CLI using ~/.claude OAuth.
#   - codex   Shells out to OpenAI Codex CLI using ~/.codex creds.
#   - kimi    Shells out to Moonshot Kimi CLI.
#
# Docker: CLI runners (claude/codex/kimi) need the host's config
# dirs mounted in via docker-compose.research.yml. The `api`
# runner is already included in the slim image.

RESEARCH_ENABLED=false
RESEARCH_RUNNERS=api
RESEARCH_DEFAULT_RUNNER=api

# Parallelism and timing
# RESEARCH_MAX_PARALLEL=5              # concurrent sub-topic agents
# RESEARCH_AGENT_TIMEOUT=600           # per-agent timeout in seconds

# Plan-phase guardrails
# RESEARCH_PLAN_MIN_SUBTOPICS=3
# RESEARCH_PLAN_MAX_SUBTOPICS=8

# Synthesis-phase output length band (characters)
# RESEARCH_SYNTHESIS_MIN_CHARS=8000
# RESEARCH_SYNTHESIS_MAX_CHARS=40000

# API runner DDG search depth
# RESEARCH_API_SEARCH_RESULTS=8        # how many DDG results per sub-topic
# RESEARCH_API_FETCH_TOP=4             # how many of those to fetch + summarise

# Per-phase LLM routing for research (Phase 2 pattern). Plan
# benefits from structured-output capable model; Synthesise
# benefits from long-context high-quality writer.
# LLM_RESEARCH_PLAN_API_KEY=
# LLM_RESEARCH_PLAN_BASE_URL=
# LLM_RESEARCH_PLAN_MODEL=
# LLM_RESEARCH_SYNTHESIS_API_KEY=
# LLM_RESEARCH_SYNTHESIS_BASE_URL=
# LLM_RESEARCH_SYNTHESIS_MODEL=


# ============================================================
# SECTION 10 — Flask server settings (advanced)
# ============================================================
# Only needed if you're running the backend outside Docker
# and want to override the defaults.

# FLASK_HOST=0.0.0.0
# FLASK_PORT=5001
# FLASK_DEBUG=true
# SECRET_KEY=mirofish-secret-key


# ============================================================
# SECTION 11 — Example provider configurations
# ============================================================
# Paste one of these over the LLM_API_KEY / LLM_BASE_URL /
# LLM_MODEL_NAME block at the top of this file to switch
# providers. All 11 wizard-supported options below.

# --- OpenRouter (free models available, recommended starter) ---
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free
# LLM_FALLBACK_MODELS=nousresearch/hermes-3-llama-3.1-405b:free,qwen/qwen3-235b-a22b:free,deepseek/deepseek-chat:free,openrouter/free

# --- OpenAI (cheapest tier: gpt-5-nano) ---
# LLM_API_KEY=sk-proj-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-5-nano

# --- Google Gemini (generous free tier, 1M context) ---
# LLM_API_KEY=AIza...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL_NAME=gemini-3-flash-preview

# --- Groq (fast free tier, renewable daily) ---
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL_NAME=llama-3.1-8b-instant

# --- DeepSeek (very cheap paid, strong quality) ---
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL_NAME=deepseek-chat

# --- Anthropic Claude (no native response_format — auto prompt-fallback) ---
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.anthropic.com/v1/
# LLM_MODEL_NAME=claude-sonnet-4-6

# --- Grok / xAI ---
# LLM_API_KEY=xai-...
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_MODEL_NAME=grok-4-1-fast-non-reasoning

# --- Alibaba DashScope / Qwen ---
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-flash

# --- Kimi / Moonshot ---
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL_NAME=moonshot-v1-8k

# --- Ollama (local, no API key, slow on CPU) ---
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL_NAME=llama3.2

# --- Custom (any other OpenAI-compatible endpoint) ---
# LLM_API_KEY=your_key
# LLM_BASE_URL=https://your-provider.example.com/v1
# LLM_MODEL_NAME=your-model-name
