# ============================================================
# LemonFish — Environment Configuration
# ============================================================
# LemonFish uses the OpenAI SDK format. Any provider with an
# OpenAI-compatible endpoint works.
#
# Run ./setup.sh for an interactive wizard that generates this
# file for you, or fill it in manually below.
#
# See docs/llm_providers.md for the full verified provider catalogue.
# ============================================================

# -------------------- PRIMARY LLM --------------------
# Pick ONE provider and fill in the three values below.
# Example defaults are shown for OpenRouter (free tier).

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free

# -------------------- FALLBACK MODELS --------------------
# Comma-separated list of models to try if the primary returns
# 429 or 5xx errors. Only relevant when using OpenRouter.
LLM_FALLBACK_MODELS=nousresearch/hermes-3-llama-3.1-405b:free,qwen/qwen3-235b-a22b:free,deepseek/deepseek-chat:free,openrouter/free

# -------------------- RESILIENCE --------------------
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=2.0

# -------------------- PER-STEP MODEL OVERRIDES --------------------
# Each pipeline step can optionally use a different provider/model.
# If a step's vars are unset, it falls back to the primary LLM_* config.
# Recommended routing:
#   Step 1 (Ontology)   - Gemini 3 Flash (1M context, free tier)
#   Step 2 (Profiles)   - Cheap JSON-capable model (Groq, gpt-5-nano)
#   Step 3 (Config)     - Any JSON-capable model
#   Step 4 (Simulation) - Free or near-free (Groq free tier, Ollama)
#   Step 5 (Report)     - Reasoning-capable (Claude Sonnet, Gemini Pro)

# Step 1 — Ontology generation (benefits from large-context models)
# LLM_ONTOLOGY_API_KEY=your_google_ai_studio_key
# LLM_ONTOLOGY_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_ONTOLOGY_MODEL=gemini-3-flash-preview
# LLM_ONTOLOGY_MAX_TEXT_LENGTH=2000000

# Step 2 — Agent persona generation (N parallel calls, cheap/fast JSON)
# LLM_PROFILES_API_KEY=gsk_your_groq_key
# LLM_PROFILES_BASE_URL=https://api.groq.com/openai/v1
# LLM_PROFILES_MODEL=llama-3.1-8b-instant

# Step 3 — Simulation config generation (small context)
# LLM_CONFIG_API_KEY=...
# LLM_CONFIG_BASE_URL=...
# LLM_CONFIG_MODEL=...

# Step 4 — Simulation (~90% of total tokens, use free tier if possible)
# LLM_SIMULATION_API_KEY=gsk_your_groq_key
# LLM_SIMULATION_BASE_URL=https://api.groq.com/openai/v1
# LLM_SIMULATION_MODEL=llama-3.1-8b-instant

# Step 5 — Report generation (reasoning-capable)
# LLM_REPORT_API_KEY=...
# LLM_REPORT_BASE_URL=...
# LLM_REPORT_MODEL=...

# -------------------- MULTI-PROVIDER POOL (Phase 4) --------------------
# Enables spreading LLM load across multiple free-tier providers.
# Each provider gets its own block: LLM_<NAME>_API_KEY/BASE_URL/MODEL.
# Names are lowercased in LLM_PROVIDERS and uppercased in variable names.
#
# LLM_PROVIDERS=groq,google,ollama
#
# LLM_GROQ_API_KEY=gsk_...
# LLM_GROQ_BASE_URL=https://api.groq.com/openai/v1
# LLM_GROQ_MODEL=llama-3.1-8b-instant
# LLM_GROQ_DAILY_TOKEN_BUDGET=500000
#
# LLM_GOOGLE_API_KEY=AIza...
# LLM_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_GOOGLE_MODEL=gemini-3-flash-preview
# LLM_GOOGLE_DAILY_TOKEN_BUDGET=1000000
#
# LLM_OLLAMA_API_KEY=ollama
# LLM_OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# LLM_OLLAMA_MODEL=llama3.2
# LLM_OLLAMA_DAILY_TOKEN_BUDGET=999999999

# ============================================================
# Zep Cloud — Memory / Knowledge Graph
# Free tier is sufficient for basic usage: https://app.getzep.com/
# ============================================================
ZEP_API_KEY=your_zep_api_key_here

# ============================================================
# OASIS Simulation Settings
# ============================================================
OASIS_DEFAULT_MAX_ROUNDS=10

# ============================================================
# Phase 8 — Research-from-prompt module (opt-in)
# ============================================================
# When RESEARCH_ENABLED=true, the backend mounts /api/research/* and the
# frontend exposes a "Start with research" Step 0 entry point. The user
# enters a vague prompt instead of uploading documents; research agents
# gather material via web search and compile it into the same source
# document the existing pipeline already consumes.
#
# Available runners (RESEARCH_RUNNERS = comma-separated subset):
#   - api      Always available. Uses the LLM_RESEARCH_PLAN_* model + DDG
#              search. Requires `pip install ddgs` (or `uv sync --extra research`).
#   - claude   Shells out to the Claude Code CLI (`claude -p ...`).
#              Uses the user's ~/.claude OAuth credentials.
#   - codex    Shells out to the OpenAI Codex CLI (`codex exec ...`).
#              Uses the user's ~/.codex credentials or OPENAI_API_KEY.
#   - kimi     Shells out to the Moonshot Kimi CLI.
#
# In Docker, CLI runners need the host's CLI config dirs mounted in via
# the docker-compose.research.yml overlay. The `api` runner works
# everywhere with no extra setup beyond LLM_API_KEY.

RESEARCH_ENABLED=false
RESEARCH_RUNNERS=api
RESEARCH_DEFAULT_RUNNER=api
# RESEARCH_MAX_PARALLEL=5
# RESEARCH_AGENT_TIMEOUT=600
# RESEARCH_PLAN_MIN_SUBTOPICS=3
# RESEARCH_PLAN_MAX_SUBTOPICS=8

# Per-phase LLM overrides for the research module (uses the same fallback
# pattern as Phase 2 step routing). Plan benefits from a structured-output
# capable model; Synthesise benefits from a long-context, high-quality writer.
# LLM_RESEARCH_PLAN_API_KEY=
# LLM_RESEARCH_PLAN_BASE_URL=
# LLM_RESEARCH_PLAN_MODEL=
# LLM_RESEARCH_SYNTHESIS_API_KEY=
# LLM_RESEARCH_SYNTHESIS_BASE_URL=
# LLM_RESEARCH_SYNTHESIS_MODEL=

# ============================================================
# Example provider configurations (commented — uncomment one set)
# ============================================================

# --- OpenAI ---
# LLM_API_KEY=sk-proj-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-5-nano

# --- Google Gemini (generous free tier, 1M context) ---
# LLM_API_KEY=AIza...
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL_NAME=gemini-3-flash-preview

# --- Groq (fast, free tier, renewable daily) ---
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL_NAME=llama-3.1-8b-instant

# --- DeepSeek (very cheap) ---
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL_NAME=deepseek-chat

# --- Anthropic Claude (limited JSON mode) ---
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.anthropic.com/v1/
# LLM_MODEL_NAME=claude-sonnet-4-6

# --- Grok (xAI) ---
# LLM_API_KEY=xai-...
# LLM_BASE_URL=https://api.x.ai/v1
# LLM_MODEL_NAME=grok-4-1-fast-non-reasoning

# --- Alibaba Qwen ---
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-flash

# --- Ollama (local, no API key needed) ---
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL_NAME=llama3.2
