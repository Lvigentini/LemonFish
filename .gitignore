# 上传文件
backend/uploads/
# Root-level uploads/ gets created if a user accidentally runs a compose
# file that uses `./uploads:/app/backend/uploads` from the repo root.
# The CLI's bundled compose is designed for a *separate* working directory,
# so this stray is only possible during dev testing.
/uploads/

# Docker 数据
data/

# Private planning notes — implementation plan, feature brainstorming,
# and anything that's "my thinking" rather than public reference.
# These files live in docs/internal/ locally but are never committed.
docs/internal/